{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug",
            //"program": "${workspaceFolder}/bin/${fileBasenameNoExtension}",
            "program": "${workspaceFolder}/bin/main",
            "args": ["--algo ${input:algorithm} --dir ${input:graphFile} ${input:test}"],
            "cwd": "${workspaceFolder}"
        }
    ],
    "inputs": [
    {
        "id": "graphFile",
        "type": "promptString",
        "description": "Path to graph input file"
    },
    {
        "id": "algorithm",
        "type": "promptString",
        "description": "Processing algorithm"
    },
    {
        "id": "test",
        "type": "promptString",
        "description": "Whether to run in test mode"
    }
]
}