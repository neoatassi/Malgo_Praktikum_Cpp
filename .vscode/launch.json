{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug",
            //"program": "${workspaceFolder}/bin/${fileBasenameNoExtension}",
            "program": "${workspaceFolder}/bin/main",
            "args": ["--algo", "${input:algorithm}", "--file", "${input:graphFile}"],
            //"args": ["--algo", "kruskal", "--file", "Graph/MST/G_1_2.txt"],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Kruskal",
            "program": "${workspaceFolder}/bin/main",
            "args": ["--algo", "kruskal", "--dir", "Graph/MST"],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug DFS",
            "program": "${workspaceFolder}/bin/main",
            "args": ["--algo", "dfs", "--dir", "Graph/Components"],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Tests Kruskal",
            "program": "${workspaceFolder}/bin/main",
            "args": ["--algo", "kruskal", "--test"],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Single File",
            "program": "${workspaceFolder}/bin/main",
            "args": ["--algo", "kruskal", "--file", "Graph/MST/G_1_2.txt"],
            "cwd": "${workspaceFolder}"
        }
    ],
    "inputs": [
    {
        "id": "graphFile",
        "type": "promptString",
        "description": "Path to graph input file"
    },
    {
        "id": "algorithm",
        "type": "promptString",
        "description": "Processing algorithm"
    },
    {
        "id": "test",
        "type": "promptString",
        "description": "Whether to run in test mode"
    }
]
}